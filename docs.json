{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MultiAgency",
  "description": "Collective Intelligence for Hire",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "products": [
      {
        "product": "About",
        "description": "",
        "color": {
          "light": "#01ec97",
          "dark": "#01ec97"
        },
        "pages": [
          "about/index",
          "about/processes",
          {
            "group": "Projects",
            "expanded": true,
            "root": "platform/configuration/index",
            "pages": [
              "projects/hire"
            ]
          },
          {
            "group": "Contributors",
            "expanded": true,
            "root": "platform/administration/index",
            "pages": [
              "contributors/join",
              "contributors/assign",
              "contributors/payment"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo/light.svg",
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/_multiagency",
      "github": "https://github.com/MultiAgency",
      "telegram": "https://t.me/+X4EScSO6NCs0OGQ5"
    }
  },
  "thumbnails": {
    "appearance": "dark",
    "background": "/images/logo.jpg"
  },
  "appearance": {
    "default": "system",
    "strict": false
  }
}
